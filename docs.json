{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AGNT",
  "colors": {
    "primary": "#FF006E",
    "light": "#FF2D6F",
    "dark": "#D1005C"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart"
        ]
      },
      {
        "group": "Your Agent",
        "pages": [
          "agent"
        ]
      },
      {
        "group": "Wallet & Commerce",
        "pages": [
          "wallet",
          "launch"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Open AGNT",
          "href": "https://agnt.social",
          "icon": "robot"
        },
        {
          "anchor": "X",
          "href": "https://x.com/agntsocial",
          "icon": "x-twitter"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Open AGNT",
      "href": "https://agnt.social"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "mcp"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/agntsocial",
      "website": "https://agnt.social"
    }
  }
}
